<?xml version="1.0" encoding="UTF-8" ?>
<properties>

    <query key="course.findAll">
        select
            *
        from courses
    </query>

    <query key="course.save">
        insert into courses (author_id , title , description , status)
        values (? , ? , ? , ?)
    </query>

    <query key="course.delete">
        delete from courses
        where course_id = ?
    </query>

    <query key="course.findById">
        select
            *
        from courses
        where course_id = ?
    </query>

    <query key="course.findCourseWithSections">
        select
            c.course_id,
            c.author_id,
            c.title,
            c.description,
            c.status,
            s.section_id,
            s.course_id AS section_course_id,
            s.title AS section_title,
            s.section_order
        from courses c
        left join course_sections s
        on c.course_id = s.course_id
        where c.course_id = ?
        order by s.section_order ASC
    </query>

    <query key="courseSection.save">
        insert into course_sections
        (course_id , title , section_order)
        values
        (? , ? , ?)
    </query>

    <query key="users.selectAll">
        select
            *
        from user
    </query>

    <query key="users.findById">
        select
            *
        from user
        where user_id = ?
    </query>

    <query key="payment.selectAll">
        select
        *
        from payment
    </query>

    <query key="refund.selectAll">
        select
        *
        from refund
    </query>

    <query key="settlement.findById">
        select
        *
        from settlement
        where instructor_id = ?
    </query>


    <query key="student.selectAll">
        select
        *
        from student
    </query>

    <query key="student.findById">
        select
        *
        from student
        where student_id = ?
    </query>

    <query key="instructor.selectAll">
        select
        *
        from instructor
    </query>

    <query key="users.login">
        SELECT user_id, user_password, user_role
        FROM user
        WHERE user_id = ? AND user_password = ?
    </query>

    <query key="users.insert">
        INSERT INTO user (user_id, user_password, user_name, user_phone_number, user_role)
        VALUES (?, ?, ?, ?, ?);
    </query>



</properties>